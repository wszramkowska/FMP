PROJECT_NAME           = "FMP"
PROJECT_BRIEF          = "Unreal Engine C++ API documentation"
OUTPUT_DIRECTORY       = docs/generated
CREATE_SUBDIRS         = NO
OUTPUT_LANGUAGE        = English
MARKDOWN_SUPPORT       = YES
AUTOLINK_SUPPORT       = YES
BUILTIN_STL_SUPPORT    = YES
CPP_CLI_SUPPORT        = NO
IDL_PROPERTY_SUPPORT   = YES
DISTRIBUTE_GROUP_DOC   = YES
GROUP_NESTED_COMPOUNDS = YES
SUBGROUPING            = YES

INPUT                  = Source docs/mainpage.dox docs/groups.dox docs/index.md
FILE_PATTERNS          = *.h *.hpp *.hh *.cpp *.cxx *.cc *.dox *.md
RECURSIVE              = YES
EXCLUDE                = Binaries Intermediate DerivedDataCache Saved .git .github .idea .vs .vscode Content Config
EXCLUDE_PATTERNS       = */Intermediate/* */Binaries/* */DerivedDataCache/* */Saved/* */*.generated.h */*.gen.cpp */ThirdParty/*
USE_MDFILE_AS_MAINPAGE =

EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = NO
EXTRACT_PRIV_VIRTUAL   = NO
EXTRACT_PACKAGE        = NO
EXTRACT_STATIC         = NO
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO
JAVADOC_AUTOBRIEF      = YES
QT_AUTOBRIEF           = NO
MULTILINE_CPP_IS_BRIEF = NO
INHERIT_DOCS           = YES

WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_IF_INCOMPLETE_DOC = YES
WARN_NO_PARAMDOC       = YES
WARN_AS_ERROR          = FAIL_ON_WARNINGS_PRINT
WARN_FORMAT            = "$file:$line: $text"
WARN_LOGFILE           = docs/generated/doxygen-warnings.log

GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_DYNAMIC_SECTIONS  = YES
HTML_COLORSTYLE        = AUTO_LIGHT
HTML_EXTRA_STYLESHEET  = docs/custom.css
HTML_HEADER            =
HTML_FOOTER            =
HTML_EXTRA_FILES       =
LAYOUT_FILE            = docs/DoxygenLayout.xml
SEARCHENGINE           = YES
SERVER_BASED_SEARCH    = NO
GENERATE_TREEVIEW      = YES
DISABLE_INDEX          = NO
FULL_SIDEBAR           = NO

GENERATE_LATEX         = NO
GENERATE_XML           = YES
XML_OUTPUT             = xml
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES
REFERENCES_LINK_SOURCE = YES

HAVE_DOT               = YES
DOT_IMAGE_FORMAT       = svg
INTERACTIVE_SVG        = YES
CLASS_GRAPH            = YES
COLLABORATION_GRAPH    = YES
GROUP_GRAPHS           = YES
INCLUDE_GRAPH          = YES
INCLUDED_BY_GRAPH      = YES
CALL_GRAPH             = NO
CALLER_GRAPH           = NO
DIRECTORY_GRAPH        = YES
DOT_TRANSPARENT        = YES

ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = YES
EXPAND_ONLY_PREDEF     = YES
SKIP_FUNCTION_MACROS   = YES
PREDEFINED             = \
  UCLASS(...)= \
  USTRUCT(...)= \
  UENUM(...)= \
  UINTERFACE(...)= \
  UFUNCTION(...)= \
  UPROPERTY(...)= \
  UDELEGATE(...)= \
  GENERATED_BODY()= \
  GENERATED_UCLASS_BODY()= \
  GENERATED_USTRUCT_BODY()= \
  GENERATED_IINTERFACE_BODY()= \
  GENERATED_BODY_LEGACY()= \
  DECLARE_DYNAMIC_MULTICAST_DELEGATE(Name)=class Name \
  DECLARE_DYNAMIC_MULTICAST_DELEGATE_OneParam(Name,T1,P1)=class Name \
  DECLARE_DYNAMIC_MULTICAST_DELEGATE_TwoParams(Name,T1,P1,T2,P2)=class Name \
  DECLARE_DYNAMIC_MULTICAST_DELEGATE_ThreeParams(Name,T1,P1,T2,P2,T3,P3)=class Name \
  DECLARE_DYNAMIC_MULTICAST_DELEGATE_FourParams(Name,T1,P1,T2,P2,T3,P3,T4,P4)=class Name \
  FMP_API= \
  MinimalAPI= \
  BlueprintType= \
  Blueprintable= \
  BlueprintSpawnableComponent= \
  EditAnywhere= \
  BlueprintReadOnly= \
  BlueprintReadWrite= \
  BlueprintAssignable= \
  BlueprintCallable= \
  BlueprintPure= \
  Category= \
  meta(...)=

ALIASES                = \
  "blueprint=\par Blueprint\n" \
  "network=\par Networking\n" \
  "thread=\par Threading\n" \
  "lifetime=\par Lifetime\n"
